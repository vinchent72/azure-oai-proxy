# Microsoft Foundry Proxy Configuration

# Foundry API Settings
FOUNDRY_API_KEY=your-foundry-api-key-here
AUTH_TOKENS=sk-dev-coding-token-432323,sk-dev-another-token

# Optional: Set specific region and endpoint
AZURE_FOUNDRY_REGION=westus
# AZURE_FOUNDRY_ENDPOINT=https://foundry-core-workspace-yong.openai.azure.com/openai/v1
ANTHROPIC_APIVERSION=2023-06-01

# Proxy Server Settings
AZURE_OPENAI_PROXY_ADDRESS=0.0.0.0:11437

# Optional: Custom model-to-deployment mappings
# Format: openai-model-name=foundry-deployment-name
# AZURE_OPENAI_MODEL_MAPPER=custom-gpt=my-gpt-deployment,custom-claude=my-claude-deployment

# Note: API keys are passed in the request headers with "api-key" or "Authorization: Bearer"
# The proxy will automatically convert them to Bearer tokens for Foundry authentication
